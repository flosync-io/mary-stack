# Mary Eval credentials — copy this file to ".env" and fill in your key.
#
# The scripts auto-load ".env" from the current folder, from ~/.mary-eval.env,
# or from a path you pass with --env-file. A real shell environment variable,
# if set, always takes precedence over this file.
#
# Keep your .env private. Do not commit it (a .gitignore is included).

DIFY_API_KEY=app-REPLACE_WITH_YOUR_DIFY_APP_API_KEY

# Optional — only change for self-hosted Dify:
DIFY_BASE_URL=https://api.dify.ai/v1
